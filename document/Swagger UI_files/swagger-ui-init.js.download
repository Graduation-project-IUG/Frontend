          "properties": {
            "reaction": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100,
              "example": 1
            }
          }
        },
        "MessageResponse": {
          "type": "object",
          "properties": {
            "message": {
              "type": "string",
              "example": "Operation successful"
            }
          }
        },
        "ValidationErrorResponse": {
          "type": "object",
          "properties": {
            "message": {
              "type": "array",
              "items": {
                "type": "object"
              },
              "example": [
                {
                  "path": [
                    "title"
                  ],
                  "message": "Minimum length of title is 5"
                }
              ]
            }
          }
        }
      }
