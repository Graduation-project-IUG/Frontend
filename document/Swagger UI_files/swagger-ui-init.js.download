              "type": "integer",
              "example": 1
            },
            "userId": {
              "type": "integer",
              "example": 7
            },
            "postId": {
              "type": "integer",
              "example": 1
            },
            "reaction": {
              "type": "integer",
              "example": 1
            },
            "createdAt": {
              "type": "string",
              "format": "date-time",
              "nullable": true
            }
          }
        },
        "RegisterRequest": {
          "type": "object",
          "required": [
            "full_name",
            "email",
            "password"
          ],
          "properties": {
            "full_name": {
              "type": "string",
              "example": "Ahmad Ali"
            },
            "email": {
              "type": "string",
              "format": "email",
              "example": "user@example.com"
            },
            "password": {
              "type": "string",
