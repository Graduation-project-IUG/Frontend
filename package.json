{
	  "name": "express-prisma-render-app",
	    "version": "1.0.0",
	      "description": "Express app with Prisma and PostgreSQL on Render",
	        "main": "server.js",
		  "scripts": {
			      "start": "node server.js",
			          "build": "prisma generate",
