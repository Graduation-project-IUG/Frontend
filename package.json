{
	"name": "express-prisma-render-app",
	"version": "1.0.0",
	"description": "Express app with Prisma and PostgreSQL on Render",
	"main": "server.js",
	"scripts": {
		"start": "node server.js",
		"build": "prisma generate",
		"postinstall": "prisma generate",
		"db:push": "prisma db push",
		"db:push:force": "prisma db push --accept-data-loss",
		"db:deploy": "prisma migrate deploy",
		"prisma:studio": "prisma studio"
	},
	"dependencies": {
		"@prisma/client": "6.19.0",
		"cors": "^2.8.5",
		"zod": "^4.4.3",
		"cookie-parser": "^1.4.7",
		"dotenv": "^16.4.7",
		"express": "^4.21.2",
		"express-session": "^1.18.1",
		"connect-pg-simple": "^10.0.0",
		"csrf-csrf": "^3.1.0",
		"pg": "^8.13.1",
		"bcryptjs": "^2.4.3"
	},
	"devDependencies": {
		"prisma": "6.19.0"
	},
	"engines": {
		"node": ">=18"
	}
}
