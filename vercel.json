{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/api-docs",
      "destination": "/api-docs/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api-docs/",
      "destination": "https://graduation-project-s30r.onrender.com/api-docs/"
    },
    {
      "source": "/api-docs/:path*",
      "destination": "https://graduation-project-s30r.onrender.com/api-docs/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://graduation-project-s30r.onrender.com/:path*"
    }
  ]
}
